# Test-Postgres connection — matches the docker-compose default. Copy to
# `.env.test` and `source .env.test` before running the integration suite.
#
# CI sets the same vars from its `services.postgres` block; the integration
# tests self-skip when these are unset.
#
# Two-role pattern (recommended): point the integration suite at the
# non-privileged `strav_app` role so RLS-scoping assertions exercise the
# policy machinery instead of degrading. Run once after `docker-compose up`:
#
#   bun run db:setup-roles   # creates strav_app (NOBYPASSRLS) + strav_admin (BYPASSRLS)
#
# Then switch DB_USER / DB_PASSWORD below to `strav_app` / `strav_app`.
# Use `strav` (the superuser) only when you need to (re-)create roles or
# debug schema-owner operations.

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=strav
DB_PASSWORD=strav
DB_DATABASE=strav_test
APP_ENV=testing
