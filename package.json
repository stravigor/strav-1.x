{
  "name": "strav-workspace",
  "version": "0.0.0",
  "description": "Strav 1.0 — modern AI-first backend framework for Bun",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "tests/e2e/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "bun test",
    "test:e2e": "bun test tests/e2e",
    "test:integration": "bun test tests/integration",
    "db:setup": "bun scripts/db-setup.ts",
    "db:setup-roles": "bun scripts/db-setup-roles.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@strav/notification": "workspace:*",
    "@strav/testing": "workspace:*",
    "@types/bun": "^1.3.14",
    "@vue/compiler-sfc": "^3.5.0",
    "typescript": "^5.6.0",
    "vue": "^3.5.0"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14"
}
