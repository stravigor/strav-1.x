{
  "name": "@strav/notification",
  "version": "1.0.0-alpha.30",
  "description": "Strav multi-channel notifications — NotificationManager fan-out across channel drivers (mail / database / log / webhook / broadcast / discord / sse). Manager+drivers shape; new channels register via `manager.extend(name, factory)`.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./mail": "./src/drivers/mail/index.ts",
    "./database": "./src/drivers/database/index.ts",
    "./log": "./src/drivers/log/index.ts",
    "./webhook": "./src/drivers/webhook/index.ts",
    "./broadcast": "./src/drivers/broadcast/index.ts",
    "./discord": "./src/drivers/discord/index.ts",
    "./sse": "./src/drivers/sse/index.ts",
    "./tenanted": "./src/drivers/database/tenanted/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@strav/kernel": "workspace:*"
  },
  "devDependencies": {
    "@strav/broadcast": "workspace:*",
    "@strav/database": "workspace:*",
    "@strav/http": "workspace:*",
    "@strav/mail": "workspace:*"
  },
  "peerDependencies": {
    "@strav/broadcast": "workspace:*",
    "@strav/database": "workspace:*",
    "@strav/http": "workspace:*",
    "@strav/mail": "workspace:*",
    "@types/bun": ">=1.3.14"
  },
  "peerDependenciesMeta": {
    "@strav/broadcast": {
      "optional": true
    },
    "@strav/database": {
      "optional": true
    },
    "@strav/http": {
      "optional": true
    },
    "@strav/mail": {
      "optional": true
    }
  }
}
