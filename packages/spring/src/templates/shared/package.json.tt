{
  "name": "{{projectName}}",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "strav": "bun bin/strav.ts",
    "dev": "bun --hot bin/strav.ts serve",
    "test": "bun test"
  },
  "dependencies": {
    "@strav/cli": "{{stravVersion}}",
    "@strav/http": "{{stravVersion}}",
    "@strav/kernel": "{{stravVersion}}"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "engines": {
    "bun": ">=1.3.14"
  }
}
